{
  "name": "c2cmarket-staging",
  "compatibility_date": "2026-07-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./frontend/.output/server/index.mjs",
  "keep_vars": true,
  "assets": {
    "directory": "./frontend/.output/public"
  },
  "vars": {
    "NUXT_PUBLIC_SITE_URL": "https://staging.c2cmarket.shop",
    "NUXT_PUBLIC_API_BASE_URL": "https://api-staging.c2cmarket.shop",
    "NUXT_PUBLIC_API_MODE": "real",
    "NUXT_API_BASE_URL": "https://api-staging.c2cmarket.shop"
  }
}
