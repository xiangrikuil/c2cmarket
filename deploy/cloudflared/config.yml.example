# C2CMarket 本机双后端 Tunnel 示例；复制到 ~/.cloudflared/config.yml 后替换占位符。
tunnel: CHANGE_ME_TUNNEL_UUID
credentials-file: /Users/CHANGE_ME/.cloudflared/CHANGE_ME_TUNNEL_UUID.json

ingress:
  - hostname: api.c2cmarket.shop
    service: http://127.0.0.1:8080
  - hostname: api-staging.c2cmarket.shop
    service: http://127.0.0.1:8081
  - service: http_status:404
