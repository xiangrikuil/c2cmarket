# Production environment template for C2CMarket.
# Copy this file to .env.production and replace every CHANGE_ME value before use.

POSTGRES_DB=c2c_market
POSTGRES_USER=c2c_market
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_PORT=5432

BACKEND_PORT=8080
APP_ENV=production
ENABLE_DEV_AUTH=false
FRONTEND_ORIGIN=https://CHANGE_ME_DOMAIN
ALLOWED_ORIGINS=https://CHANGE_ME_DOMAIN

OAUTH_PROVIDER_MODE=oauth2
OAUTH_CLIENT_ID=CHANGE_ME_OAUTH_CLIENT_ID
OAUTH_CLIENT_SECRET=CHANGE_ME_OAUTH_CLIENT_SECRET
OAUTH_AUTHORIZE_URL=https://CHANGE_ME_OAUTH_PROVIDER/oauth/authorize
OAUTH_TOKEN_URL=https://CHANGE_ME_OAUTH_PROVIDER/oauth/token
OAUTH_USERINFO_URL=https://CHANGE_ME_OAUTH_PROVIDER/api/user
OAUTH_REDIRECT_URL=https://CHANGE_ME_DOMAIN/api/v1/auth/oauth/callback
OAUTH_SCOPES=openid profile

CONTACT_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_MINIMUM_SECRET
CONTACT_FINGERPRINT_KEY=CHANGE_ME_DIFFERENT_32_BYTE_MINIMUM_SECRET
CONTACT_KEY_VERSION=prod-v1

EMAIL_PROVIDER=aliyun_directmail
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=noreply@CHANGE_ME_DOMAIN
SMTP_PASSWORD=CHANGE_ME_DIRECTMAIL_SMTP_PASSWORD
MAIL_FROM_ADDRESS=noreply@CHANGE_ME_DOMAIN
MAIL_FROM_NAME=C2CMarket

VITE_API_MODE=real
VITE_API_BASE_URL=https://CHANGE_ME_DOMAIN
