# Staging environment template for C2CMarket.
# Copy this file to .env.staging and replace every CHANGE_ME value before use.

POSTGRES_DB=c2c_market_staging
POSTGRES_USER=c2c_market_staging
POSTGRES_PASSWORD=CHANGE_ME_DIFFERENT_STAGING_DATABASE_PASSWORD
POSTGRES_PORT=5433

BACKEND_PORT=8081
APP_ENV=production
ENABLE_DEV_AUTH=false
FRONTEND_ORIGIN=https://staging.c2cmarket.shop
ALLOWED_ORIGINS=https://staging.c2cmarket.shop
TRUST_X_FORWARDED_FOR=true
TRUSTED_PROXIES=172.16.0.0/12

OAUTH_PROVIDER_MODE=oauth2
OAUTH_CLIENT_ID=CHANGE_ME_STAGING_OAUTH_CLIENT_ID
OAUTH_CLIENT_SECRET=CHANGE_ME_STAGING_OAUTH_CLIENT_SECRET
OAUTH_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
OAUTH_TOKEN_URL=https://connect.linuxdo.org/oauth2/token
OAUTH_USERINFO_URL=https://connect.linuxdo.org/api/user
OAUTH_REDIRECT_URL=https://api-staging.c2cmarket.shop/api/v1/auth/oauth/callback
OAUTH_SCOPES=openid profile

CONTACT_ENCRYPTION_KEY=CHANGE_ME_DIFFERENT_STAGING_32_BYTE_MINIMUM_SECRET
CONTACT_FINGERPRINT_KEY=CHANGE_ME_DIFFERENT_STAGING_32_BYTE_MINIMUM_SECRET
CONTACT_KEY_VERSION=staging-v1

C2C_BOOTSTRAP_ADMIN_USERNAME=admin
C2C_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ONE_TIME_STAGING_BOOTSTRAP_PASSWORD

EMAIL_PROVIDER=aliyun_directmail
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=CHANGE_ME_VERIFIED_DIRECTMAIL_ACCOUNT
SMTP_PASSWORD=CHANGE_ME_DIRECTMAIL_SMTP_PASSWORD
MAIL_FROM_ADDRESS=CHANGE_ME_VERIFIED_SENDER_ADDRESS
MAIL_FROM_NAME=C2CMarket Staging

NUXT_PUBLIC_API_MODE=real
NUXT_PUBLIC_SITE_URL=https://staging.c2cmarket.shop
NUXT_PUBLIC_API_BASE_URL=https://api-staging.c2cmarket.shop
NUXT_API_BASE_URL=https://api-staging.c2cmarket.shop
NUXT_PUBLIC_UMAMI_ENABLED=false
NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://CHANGE_ME_UMAMI_DOMAIN/script.js
NUXT_PUBLIC_UMAMI_WEBSITE_ID=CHANGE_ME_UMAMI_WEBSITE_ID
NUXT_PUBLIC_UMAMI_DOMAINS=staging.c2cmarket.shop
NUXT_PUBLIC_UMAMI_HOST_URL=https://CHANGE_ME_UMAMI_DOMAIN
NUXT_PUBLIC_UMAMI_DEBUG=false
